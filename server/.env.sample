# FUXA Server Configuration
# Copy this file to .env and configure as needed

# Server Port
PORT=1881

# Security Settings
# Enable authentication and authorization
SECURE_ENABLED=false
SECRET_CODE=frangoteam751
TOKEN_EXPIRES_IN=1h

# Play Restriction Feature
# Enable view access control based on user/role restrictions
# When enabled, views will be filtered based on play_restrictions table
# Default: false
PLAY_RESTRICTION_ENABLED=false

# Logging
LOG_API_LEVEL=tiny

# Database
DAQ_ENABLED=true
DAQ_TOKENIZER=24

# API Settings
API_MAX_LENGTH=100MB

# CORS
ALLOWED_ORIGINS=*
